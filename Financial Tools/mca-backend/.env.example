# Required: keep this on backend/server only. Never put it in HTML or localStorage.
DATA_GOV_API_KEY=your_key_here

# Port for local backend proxy
PORT=8300

# Frontend origin. Use * only for local testing. For production set exact domain, e.g. https://crm.yourdomain.com
FRONTEND_ORIGIN=*

# data.gov.in endpoint config. If your data.gov.in API console gives a different resource/API path, paste it here.
DATA_GOV_BASE_URL=https://api.data.gov.in
DATA_GOV_MCA_ENDPOINT_PATH=/resource/registrars-companies-roc-wise-company-master-data

# Request behavior
REQUEST_TIMEOUT_MS=12000
DATA_GOV_LIMIT=25
CACHE_TTL_SECONDS=600
