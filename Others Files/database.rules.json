    "activityLogs": { ".read": "auth != null", ".write": "auth != null" },
    "hrms": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email === 'abhinav.sirohi@nexfund.in'"
    },
    "profiles": { ".read": "auth != null", ".write": "auth != null" },
